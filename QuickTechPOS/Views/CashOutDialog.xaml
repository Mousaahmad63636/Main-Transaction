<Window x:Class="QuickTechPOS.Views.CashOutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cash Out" 
        Height="350" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Cash Out" 
                   FontSize="20" 
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,15"/>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Drawer Information -->
            <Border Grid.Row="0" 
                    Background="#F8F9FA" 
                    BorderBrush="#DADADA" 
                    BorderThickness="1" 
                    CornerRadius="4" 
                    Padding="15"
                    Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" 
                               Text="Drawer ID:" 
                               FontWeight="Bold"
                               Margin="0,0,0,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" 
                               Text="{Binding Drawer.DrawerId}"
                               Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" 
                               Text="Current Balance:" 
                               FontWeight="Bold"
                               Margin="0,0,0,5"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" 
                               Text="{Binding Drawer.FormattedCurrentBalance}"
                               Margin="0,0,0,5"/>
                </Grid>
            </Border>

            <!-- Cash Out Amount -->
            <TextBlock Grid.Row="1" 
                       Text="Cash Out Amount:" 
                       FontWeight="Bold"
                       Margin="0,0,0,5"/>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="$" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="5,0,5,0"/>
                <TextBox Grid.Column="1" 
                         Text="{Binding CashOutAmount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" 
                         Height="32"
                         Padding="5,0"
                         VerticalContentAlignment="Center"/>
            </Grid>

            <!-- Notes/Reason -->
            <TextBlock Grid.Row="3" 
                       Text="Reason for Cash Out (required):" 
                       FontWeight="Bold"
                       Margin="0,15,0,5"/>
            <TextBox Grid.Row="4"
                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" 
                     Height="80"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Padding="5"
                     Margin="0,0,0,10"/>

            <!-- Error message -->
            <TextBlock Grid.Row="5" 
                       Text="{Binding ErrorMessage}" 
                       Foreground="Red" 
                       TextWrapping="Wrap" 
                       Margin="0,5,0,0" 
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

            <!-- Loading indicator -->
            <ProgressBar Grid.Row="6" 
                         IsIndeterminate="True" 
                         Height="4" 
                         Margin="0,5,0,0"
                         Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,15,0,0">
            <Button Content="Cancel" 
                    Command="{Binding CancelCommand}"
                    Width="80" 
                    Height="32"
                    Margin="0,0,10,0"/>
            <Button Content="Execute Cash Out" 
                    Command="{Binding ExecuteCashOutCommand}"
                    Width="120" 
                    Height="32"
                    Background="#E74C3C" 
                    Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>