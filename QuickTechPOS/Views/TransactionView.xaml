<UserControl x:Class="QuickTechPOS.Views.TransactionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuickTechPOS"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <local:BooleanToIndexConverter x:Key="BooleanToIndexConverter"/>
        <local:BooleanToWholesaleTextConverter x:Key="BooleanToWholesaleTextConverter"/>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                        BorderThickness="{TemplateBinding BorderThickness}"
                        BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#94A3B8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#64748B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#475569"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#10B981"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#059669"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#EF4444"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F59E0B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D97706"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="CardHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Fixed top nav bar with properly positioned buttons -->
        <Border Grid.Row="0" Background="#1E293B" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="{DynamicResource ApplicationTitle}" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Drawer}" 
                               Foreground="#94A3B8" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>

                    <Border Background="#059669" 
                            Padding="8,4"
                            Visibility="{Binding IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{DynamicResource DrawerOpen}" 
                                   Foreground="White" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Background="#DC2626" 
                            Padding="8,4"
                            Visibility="{Binding IsDrawerOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock Text="{DynamicResource DrawerClosed}" 
                                   Foreground="White" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Wholesale Mode Combo Box -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            Margin="0,0,10,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource PriceMode}" 
                               Foreground="White" 
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox Width="120" 
                              Height="30"
                              SelectedIndex="{Binding WholesaleMode, Converter={StaticResource BooleanToIndexConverter}}">
                        <ComboBoxItem Content="{DynamicResource RetailMode}"/>
                        <ComboBoxItem Content="{DynamicResource WholesaleMode}"/>
                    </ComboBox>
                </StackPanel>

                <!-- Open Drawer button - Only visible when drawer is closed -->
                <Button Grid.Column="3" 
                        Content="{DynamicResource OpenDrawerBtn}" 
                        Command="{Binding OpenDrawerCommand}"
                        Style="{StaticResource SuccessButton}"
                        Margin="0,0,10,0"
                        Visibility="{Binding IsDrawerOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                <!-- Cash Out button - Only visible when drawer is open -->
                <Button Grid.Column="4" 
                        Content="{DynamicResource CashOutBtn}" 
                        Command="{Binding CashOutCommand}"
                        Style="{StaticResource WarningButton}"
                        Margin="0,0,10,0"
                        Visibility="{Binding IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Close Drawer button - Only visible when drawer is open -->
                <Button Grid.Column="5" 
                        Content="{DynamicResource CloseDrawerBtn}" 
                        Command="{Binding CloseDrawerCommand}"
                        Style="{StaticResource DangerButton}"
                        Margin="0,0,10,0"
                        Visibility="{Binding IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Logout button always on the far right -->
                <Button Grid.Column="6" 
                        Content="{DynamicResource LogoutButton}" 
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource SecondaryButton}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" 
                        Style="{StaticResource CardPanelStyle}" 
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" 
                                Style="{StaticResource CardHeaderStyle}">
                            <TextBlock Text="{DynamicResource Customer}" 
                                       Style="{StaticResource SectionTitle}" 
                                       Margin="0"/>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="16">
                            <TextBlock Text="{Binding CustomerName}" 
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource SelectCustomer}" 
                                        Command="{Binding SelectCustomerCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,10,0" Height="33"/>

                                <Button Content="{DynamicResource AddNewCustomer}" 
                                        Command="{Binding AddCustomerCommand}"
                                        Style="{StaticResource SecondaryButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" 
                        Style="{StaticResource CardPanelStyle}" 
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" 
                                Style="{StaticResource CardHeaderStyle}">
                            <TextBlock Text="{DynamicResource ScanBarcode}" 
                                       Style="{StaticResource SectionTitle}" 
                                       Margin="0"/>
                        </Border>

                        <Grid Grid.Row="1" Margin="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" 
                                     Text="{Binding BarcodeQuery, UpdateSourceTrigger=PropertyChanged}" 
                                     KeyDown="BarcodeSearch_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource SearchBox}">
                                        <Style.Resources>
                                            <VisualBrush x:Key="HintBrush" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="{DynamicResource EnterScanBarcode}" FontStyle="Italic" Margin="10,0,0,0" />
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Style.Resources>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="{x:Null}">
                                                <Setter Property="Background" Value="{StaticResource HintBrush}" />
                                            </Trigger>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background" Value="{StaticResource HintBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <Button Grid.Column="1" 
                                    Content="{DynamicResource ScanButton}" 
                                    Command="{Binding SearchBarcodeCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="8,0,0,0"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" 
                        Style="{StaticResource CardPanelStyle}" 
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" 
                                Style="{StaticResource CardHeaderStyle}">
                            <TextBlock Text="{DynamicResource SearchProducts}" 
                                       Style="{StaticResource SectionTitle}" 
                                       Margin="0"/>
                        </Border>

                        <Grid Grid.Row="1" Margin="16">
                            <!-- This is your ComboBox with the corrected ItemTemplate -->
                            <ComboBox x:Name="ProductSearchComboBox"
                                      ItemsSource="{Binding SearchedProducts}"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      Text="{Binding NameQuery, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedItem="{Binding SelectedProduct}"
                                      Height="36"
                                      Padding="8,5"
                                      StaysOpenOnEdit="True"
                                      TextBoxBase.TextChanged="ProductSearch_TextChanged"
                                      SelectionChanged="ProductSearch_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                                       Text="{Binding Name}" 
                                                       FontWeight="SemiBold"/>

                                            <StackPanel Grid.Row="1" Grid.Column="0" 
                                                        Orientation="Horizontal" 
                                                        Margin="0,4,0,0">
                                                <TextBlock Text="{Binding FormattedSalePrice}" 
                                                           FontWeight="Bold" 
                                                           Foreground="#2563EB" 
                                                           Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding StockStatus}" 
                                                           Foreground="#64748B" 
                                                           FontSize="12"/>
                                            </StackPanel>

                                            <!-- Add the box information if available -->
                                            <StackPanel Grid.Row="2" Grid.Column="0" 
                                                        Orientation="Vertical" 
                                                        Margin="0,4,0,0"
                                                        Visibility="{Binding ItemsPerBox, Converter={StaticResource PositiveIntToVisibilityConverter}}">
                                                <TextBlock>
                                                    <Run Text="{DynamicResource BoxPrice}" FontSize="12"/>
                                                    <Run Text="{Binding FormattedBoxSalePrice, Mode=OneWay}" FontWeight="Bold" Foreground="#2563EB"/>
                                                    <Run Text="(" FontSize="12"/>
                                                    <Run Text="{Binding ItemsPerBox, Mode=OneWay}" FontSize="12"/>
                                                    <Run Text="{DynamicResource ItemsPerBox}" FontSize="12"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding BoxStockStatus}" 
                                                           Foreground="#64748B" 
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="3" 
                        Style="{StaticResource CardPanelStyle}" 
                        VerticalAlignment="Top">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" 
                                Style="{StaticResource CardHeaderStyle}">
                            <TextBlock Text="{DynamicResource TransactionLookup}" 
                                       Style="{StaticResource SectionTitle}" 
                                       Margin="0"/>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="16">
                            <TextBlock Text="{DynamicResource TransactionNumber}" 
                                       Style="{StaticResource HeaderText}"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" 
                                         Text="{Binding TransactionLookupId, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource SearchBox}"/>

                                <Button Grid.Column="1" 
                                        Content="◀" 
                                        Style="{StaticResource NavButtonStyle}"
                                        Command="{Binding PreviousTransactionCommand}"
                                        IsEnabled="{Binding CanNavigatePrevious}"
                                        Margin="8,0,4,0"/>

                                <Button Grid.Column="2" 
                                        Content="▶" 
                                        Style="{StaticResource NavButtonStyle}"
                                        Command="{Binding NextTransactionCommand}"
                                        IsEnabled="{Binding CanNavigateNext}"
                                        Margin="4,0,8,0"/>

                                <Button Grid.Column="3" 
                                        Content="{DynamicResource LookupButton}" 
                                        Command="{Binding LookupTransactionCommand}"
                                        Style="{StaticResource PrimaryButton}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" 
                    Style="{StaticResource CardPanelStyle}" 
                    Margin="16,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Style="{StaticResource CardHeaderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource ShoppingCart}" 
                                           Style="{StaticResource SectionTitle}"
                                           Margin="0"
                                           Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{DynamicResource EditingTransaction}" 
                                               Style="{StaticResource SectionTitle}"
                                               Foreground="#DC2626"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource EditingMessage}" 
                                               FontSize="13" 
                                               Foreground="#64748B"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="{DynamicResource ClearCart}" 
                                    Command="{Binding ClearCartCommand}"
                                    Style="{StaticResource DangerButton}" Margin="0,0,0,-8"/>
                        </Grid>
                    </Border>

                    <ListView Grid.Row="1" 
                              ItemsSource="{Binding CartItems}"
                              SelectedItem="{Binding SelectedCartItem}"
                              BorderThickness="0"
                              Background="Transparent"
                              Margin="0,1,0,0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{DynamicResource Product}" Width="220">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" 
                                                       TextWrapping="Wrap" 
                                                       FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{DynamicResource Product}" Width="220">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Product.Name}" 
                                                       TextWrapping="Wrap" 
                                                       FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="{DynamicResource Price}" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding UnitPrice, StringFormat='${0:F2}'}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="{DynamicResource Quantity}" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                                     Width="50" 
                                                     Height="28"
                                                     BorderBrush="#CBD5E1"
                                                     VerticalContentAlignment="Center"
                                                     HorizontalContentAlignment="Center"
                                                     LostFocus="Quantity_LostFocus"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="{DynamicResource Discount}" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" 
                                                         Text="{Binding DiscountValue, UpdateSourceTrigger=PropertyChanged}" 
                                                         Width="50" 
                                                         Height="28"
                                                         BorderBrush="#CBD5E1"
                                                         VerticalContentAlignment="Center"
                                                         HorizontalContentAlignment="Right"
                                                         LostFocus="Discount_LostFocus"/>
                                                <ComboBox Grid.Column="1" 
                                                          Width="35" 
                                                          Height="28"
                                                          VerticalContentAlignment="Center"
                                                          BorderBrush="#CBD5E1"
                                                          SelectedIndex="{Binding DiscountType}"
                                                          SelectionChanged="DiscountType_SelectionChanged">
                                                    <ComboBoxItem Content="$"/>
                                                    <ComboBoxItem Content="%"/>
                                                </ComboBox>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="{DynamicResource Total}" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Total, StringFormat='${0:F2}'}" 
                                                       FontWeight="Bold" 
                                                       Foreground="#1E293B"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" 
                                                    Command="{Binding DataContext.RemoveFromCartCommand, 
                                                             RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    Width="28" Height="28"
                                                    Background="Transparent"
                                                    Foreground="#EF4444"
                                                    FontWeight="Bold"
                                                    BorderThickness="0"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="350"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" 
                                    Orientation="Horizontal" 
                                    VerticalAlignment="Bottom" 
                                    HorizontalAlignment="Center"
                                    Margin="16,0,16,16"
                                    Visibility="{Binding IsTransactionLoaded, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <Button Content="{DynamicResource EditTransaction}" 
                                    Command="{Binding EditTransactionCommand}"
                                    Style="{StaticResource SuccessButton}"
                                    Height="40"
                                    FontSize="14"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <StackPanel Orientation="Horizontal" 
                                        Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Content="{DynamicResource CancelChanges}" 
                                        Command="{Binding LookupTransactionCommand}"
                                        CommandParameter="{Binding LoadedTransaction.TransactionId}"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="40"
                                        FontSize="14"
                                        Margin="0,0,16,0"/>

                                <Button Content="{DynamicResource SaveChanges}" 
                                        Command="{Binding SaveTransactionCommand}"
                                        Style="{StaticResource DangerButton}"
                                        Height="40"
                                        FontSize="14"
                                        FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1" 
                                Background="#F8FAFC" 
                                BorderBrush="#E2E8F0" 
                                BorderThickness="1" 
                                Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                           Text="{DynamicResource Total}" 
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="0" Grid.Column="1" 
                                           Text="{Binding TotalAmount, StringFormat='${0:F2}'}" 
                                           FontWeight="Bold"
                                           FontSize="18"
                                           Foreground="#1E293B"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,10"/>

                                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                        BorderBrush="#E2E8F0" 
                                        BorderThickness="0,1,0,0" 
                                        Margin="0,0,0,10"/>

                                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="{DynamicResource AmountLBP}" 
                                               FontWeight="Bold"
                                               Foreground="#2563EB"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding ExchangeAmount, StringFormat='LBP {0:N0}'}" 
                                               FontWeight="Bold"
                                               Foreground="#2563EB"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <TextBlock Grid.Row="3" Grid.Column="0" 
                                           Text="{DynamicResource Payment}" 
                                           Foreground="#1E293B"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,5"/>

                                <TextBox Grid.Row="3" Grid.Column="1" 
                                         Text="{Binding PaidAmount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="120"
                                         Height="32"
                                         Padding="8,0"
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Right"
                                         BorderBrush="#CBD5E1"
                                         Margin="0,0,0,5"/>

                                <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                                          Content="{DynamicResource AddToDebt}" 
                                          IsChecked="{Binding AddToCustomerDebt}"
                                          Foreground="#1E293B"
                                          Margin="0,10,0,0"/>

                                <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
                                      Visibility="{Binding AddToCustomerDebt, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      Margin="0,10,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="{DynamicResource AmountToDebt}" 
                                               FontWeight="Bold"
                                               Foreground="#EF4444"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding AmountToDebt, StringFormat='${0:F2}'}" 
                                               FontWeight="Bold"
                                               Foreground="#EF4444"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                    <!-- When no transaction is loaded (normal checkout mode) -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                Visibility="{Binding IsTransactionLoaded, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <Button Content="{DynamicResource CompleteSale}" 
                                                Command="{Binding CheckoutCommand}"
                                                Style="{StaticResource SuccessButton}"
                                                Height="48"
                                                Width="220"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                IsEnabled="{Binding IsDrawerOpen}">
                                            <Button.ToolTip>
                                                <ToolTip Content="{Binding DrawerStatusToolTip}"/>
                                            </Button.ToolTip>
                                        </Button>
                                    </StackPanel>

                                    <!-- When viewing a transaction -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                                                Visibility="{Binding IsTransactionLoaded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Button Content="{DynamicResource NewSale}" 
                                                Command="{Binding ClearCartCommand}"
                                                Style="{StaticResource PrimaryButton}"
                                                Height="48"
                                                Width="140"
                                                FontSize="14"
                                                Margin="0,0,16,0"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <Button.ToolTip>
                                                <ToolTip Content="{DynamicResource StartNewTransaction}"/>
                                            </Button.ToolTip>
                                        </Button>

                                        <Button Content="{DynamicResource PrintReceipt}" 
                                                Command="{Binding PrintReceiptCommand}"
                                                Style="{StaticResource WarningButton}"
                                                Height="48"
                                                Width="160"
                                                FontSize="14"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <Button.ToolTip>
                                                <ToolTip Content="{DynamicResource PrintReceiptTooltip}"/>
                                            </Button.ToolTip>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" 
                Background="#F1F5F9" 
                BorderBrush="#E2E8F0" 
                BorderThickness="0,1,0,0" 
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="#1E293B" 
                               VerticalAlignment="Center"/>

                    <Border Background="#BFDBFE" 
                            Visibility="{Binding IsTransactionLoaded, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="16,0,0,0" 
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource ViewingTransaction}" 
                                       Foreground="#1E40AF" 
                                       Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            <TextBlock Text="{DynamicResource EditingTransactionNumber}" 
                                       Foreground="#DC2626" 
                                       FontWeight="Bold"
                                       Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding LoadedTransaction.TransactionId}" 
                                       FontWeight="Bold" 
                                       Foreground="#1E40AF"/>
                            <TextBlock Text=" - " Foreground="#1E40AF"/>
                            <TextBlock Text="{Binding LoadedTransaction.Status}" Foreground="#1E40AF"/>
                            <TextBlock Text=" - " Foreground="#1E40AF"/>
                            <TextBlock Text="{Binding LoadedTransaction.FormattedDate}" Foreground="#1E40AF"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ProgressBar Grid.Column="1" 
                             IsIndeterminate="True" 
                             Width="120" 
                             Height="4"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>