<UserControl x:Class="QuickTechPOS.Views.TransactionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- App Bar (Blue) -->
        <Border Grid.Row="0" Background="#2196F3" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Title -->
                <TextBlock Grid.Column="0" 
                       Text="QuickTech POS" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       VerticalAlignment="Center"/>

                <!-- Welcome Message -->
                <TextBlock Grid.Column="1" 
                       Text="{Binding WelcomeMessage}" 
                       FontSize="16" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>

                <!-- Logout Button -->
                <Button Grid.Column="2" 
                    Content="Logout" 
                    Command="{Binding LogoutCommand}"
                    Background="Transparent"
                    Foreground="White"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Transaction Bar (Dark Blue) -->
        <Border Grid.Row="1" Background="#2C3E50" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Customer Section - NOW ON THE LEFT -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Customer: " 
                           Foreground="White" 
                           VerticalAlignment="Center" 
                           Margin="0,0,5,0"/>

                    <!-- Customer Display -->
                    <TextBlock Text="{Binding CustomerName}" 
                           FontWeight="Bold"
                           Foreground="#2196F3"
                           Margin="0,0,10,0" 
                           VerticalAlignment="Center"/>

                    <!-- Select Customer Button -->
                    <Button Content="Select" 
                        ToolTip="Select Customer"
                        Command="{Binding SelectCustomerCommand}"
                        Padding="8,2"
                        Margin="0,0,5,0"
                        Background="#2196F3"
                        Foreground="White"/>

                    <!-- Add Customer Button -->
                    <Button Content="+" 
                        ToolTip="Add New Customer"
                        Command="{Binding AddCustomerCommand}"
                        Width="30"
                        Background="#2196F3"
                        Foreground="White"/>
                </StackPanel>

                <!-- Transaction Navigation -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Transaction #" 
                           Foreground="White" 
                           VerticalAlignment="Center" 
                           Margin="0,0,5,0"/>

                    <TextBox Text="{Binding TransactionLookupId, UpdateSourceTrigger=PropertyChanged}" 
                         Width="80" 
                         Height="28"
                         VerticalContentAlignment="Center"
                         Margin="0,0,5,0"/>

                    <Button Content="◀" 
                        ToolTip="Previous Transaction"
                        Command="{Binding PreviousTransactionCommand}"
                        Width="28" Height="28"
                        Margin="0,0,5,0"
                        IsEnabled="{Binding CanNavigatePrevious}"/>

                    <Button Content="▶" 
                        ToolTip="Next Transaction"
                        Command="{Binding NextTransactionCommand}"
                        Width="28" Height="28"
                        Margin="0,0,5,0"
                        IsEnabled="{Binding CanNavigateNext}"/>

                    <Button Content="Lookup" 
                        Command="{Binding LookupTransactionCommand}"
                        Height="28"
                        Padding="10,0"
                        Background="#3498DB" 
                        Foreground="White"/>
                </StackPanel>

                <!-- Drawer Section -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="DRAWER: " 
                           Foreground="White" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>

                    <TextBlock Text="OPEN" 
                           Foreground="#2ECC71" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Visibility="{Binding IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <TextBlock Text="CLOSED" 
                           Foreground="#E74C3C" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Visibility="{Binding IsDrawerOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                    <Button Content="Cash Out" 
                        Command="{Binding CashOutCommand}"
                        Background="#F39C12"
                        Foreground="White"
                        Margin="5,0"
                        Padding="10,5"
                        Visibility="{Binding IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="Close Drawer" 
                        Command="{Binding CloseDrawerCommand}"
                        Background="#E74C3C"
                        Foreground="White"
                        Padding="10,5"
                        Visibility="{Binding IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="Open Drawer" 
                        Command="{Binding OpenDrawerCommand}"
                        Background="#2ECC71"
                        Foreground="White"
                        Padding="10,5"
                        Visibility="{Binding IsDrawerOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Product Search and Scanning -->
            <Border Grid.Column="0" Background="White" CornerRadius="5" Margin="0,0,10,0" 
                    BorderBrush="#DADADA" BorderThickness="1" Effect="{StaticResource DropShadowEffect}">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Section Title -->
                    <TextBlock Grid.Row="0" Text="PRODUCT ENTRY" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>

                    <!-- Barcode Scanning -->
                    <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="4" BorderBrush="#DADADA" BorderThickness="1" Padding="10" Margin="0,0,0,15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="SCAN BARCODE" FontSize="12" FontWeight="Bold" Margin="0,0,0,5" Foreground="#2C3E50"/>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" 
                                         Text="{Binding BarcodeQuery, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="34"
                                         VerticalContentAlignment="Center"
                                         Padding="10,0"
                                         BorderThickness="1"
                                         BorderBrush="#DADADA"
                                         KeyDown="BarcodeSearch_KeyDown">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Resources>
                                                <VisualBrush x:Key="HintBrush" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Enter or scan barcode..." FontStyle="Italic" Margin="10,0,0,0" />
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Style.Resources>
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="{x:Null}">
                                                    <Setter Property="Background" Value="{StaticResource HintBrush}" />
                                                </Trigger>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background" Value="{StaticResource HintBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <Button Grid.Column="1" 
                                        Content="Scan" 
                                        Command="{Binding SearchBarcodeCommand}"
                                        Height="34"
                                        Padding="15,0"
                                        Margin="5,0,0,0"
                                        Background="#3498DB" 
                                        Foreground="White"
                                        BorderThickness="0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Product Search -->
                    <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="4" BorderBrush="#DADADA" BorderThickness="1" Padding="10" Margin="0,0,0,15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="SEARCH PRODUCTS" FontSize="12" FontWeight="Bold" Margin="0,0,0,5" Foreground="#2C3E50"/>

                            <ComboBox Grid.Row="1"
                                      x:Name="ProductSearchComboBox"
                                      ItemsSource="{Binding SearchedProducts}"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      Text="{Binding NameQuery, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedItem="{Binding SelectedProduct}"
                                      Height="34"
                                      Padding="8,5"
                                      StaysOpenOnEdit="True"
                                      TextBoxBase.TextChanged="ProductSearch_TextChanged"
                                      SelectionChanged="ProductSearch_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontWeight="Bold"/>

                                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding FormattedSalePrice}" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding StockStatus}" Foreground="#7F8C8D" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right Panel - Cart and Checkout -->
            <Border Grid.Column="1" Background="White" CornerRadius="5" Margin="10,0,0,0" 
                    BorderBrush="#DADADA" BorderThickness="1" Effect="{StaticResource DropShadowEffect}">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cart Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Cart Title -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="SHOPPING CART" 
                                       FontSize="16" 
                                       FontWeight="Bold"
                                       Foreground="#2C3E50"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <TextBlock Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Run Text="EDITING TRANSACTION" FontSize="16" FontWeight="Bold" Foreground="#E74C3C"/>
                                <Run Text=" (make changes and save when complete)" FontSize="12" Foreground="#7F8C8D"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Clear Cart Button -->
                        <Button Grid.Column="1"
                                Content="Clear Cart" 
                                Command="{Binding ClearCartCommand}"
                                Height="30"
                                Padding="12,0"
                                Background="#E74C3C" 
                                Foreground="White"
                                BorderThickness="0"/>
                    </Grid>

                    <!-- Cart Items List -->
                    <Border Grid.Row="1" 
                            Background="#F8F9FA" 
                            BorderBrush="#DADADA" 
                            BorderThickness="1" 
                            CornerRadius="4">
                        <ListView ItemsSource="{Binding CartItems}"
                                  SelectedItem="{Binding SelectedCartItem}"
                                  BorderThickness="0"
                                  Background="Transparent">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="PRODUCT" Width="220">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Product.Name}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="PRICE" Width="90">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding UnitPrice, StringFormat='${0:F2}'}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="QTY" Width="70">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                                         Width="45" 
                                                         Height="24"
                                                         BorderBrush="#DADADA"
                                                         VerticalContentAlignment="Center"
                                                         HorizontalContentAlignment="Center"
                                                         LostFocus="Quantity_LostFocus"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="DISCOUNT" Width="110">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" 
                                                            Text="{Binding DiscountValue, UpdateSourceTrigger=PropertyChanged}" 
                                                            Width="50" 
                                                            Height="24"
                                                            BorderBrush="#DADADA"
                                                            VerticalContentAlignment="Center"
                                                            HorizontalContentAlignment="Right"
                                                            LostFocus="Discount_LostFocus"/>
                                                    <ComboBox Grid.Column="1" 
                                                             Width="35" 
                                                             Height="24"
                                                             VerticalContentAlignment="Center"
                                                             BorderBrush="#DADADA"
                                                             SelectedIndex="{Binding DiscountType}"
                                                             SelectionChanged="DiscountType_SelectionChanged">
                                                        <ComboBoxItem Content="$"/>
                                                        <ComboBoxItem Content="%"/>
                                                    </ComboBox>
                                                </Grid>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="TOTAL" Width="90">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Total, StringFormat='${0:F2}'}" 
                                                           FontWeight="Bold" 
                                                           Foreground="#2C3E50"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="40">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕" 
                                                        Command="{Binding DataContext.RemoveFromCartCommand, 
                                                                 RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"
                                                        Width="24" Height="24"
                                                        Background="Transparent"
                                                        Foreground="#E74C3C"
                                                        FontWeight="Bold"
                                                        BorderThickness="0"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <!-- Checkout Section -->
                    <Grid Grid.Row="2" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="350"/>
                        </Grid.ColumnDefinitions>

                        <!-- Transaction Buttons - Left -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,10,0"
                                    Visibility="{Binding IsTransactionLoaded, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Content="New Transaction" 
                                    Command="{Binding ClearCartCommand}"
                                    Height="38"
                                    Width="130"
                                    Margin="0,0,10,0"
                                    Background="#3498DB" 
                                    Foreground="White"
                                    BorderThickness="0"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <Button Content="Edit Transaction" 
                                    Command="{Binding EditTransactionCommand}"
                                    Height="38"
                                    Width="130"
                                    Background="#2ECC71" 
                                    Foreground="White"
                                    BorderThickness="0"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <Button Content="Cancel" 
                                    Command="{Binding LookupTransactionCommand}"
                                    CommandParameter="{Binding LoadedTransaction.TransactionId}"
                                    Height="38"
                                    Width="130"
                                    Background="#7F8C8D" 
                                    Foreground="White"
                                    BorderThickness="0"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <Button Content="Save Changes" 
                                    Command="{Binding SaveTransactionCommand}"
                                    Height="38"
                                    Width="130"
                                    Margin="10,0,0,0"
                                    Background="#E74C3C" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Payment and Total Box - Right -->
                        <Border Grid.Column="1" 
                                Background="#F8F9FA" 
                                BorderBrush="#DADADA" 
                                BorderThickness="1" 
                                CornerRadius="4" 
                                Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Total -->
                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                           Text="TOTAL AMOUNT:" 
                                           FontWeight="Bold"
                                           Foreground="#2C3E50"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="0" Grid.Column="1" 
                                           Text="{Binding TotalAmount, StringFormat='${0:F2}'}" 
                                           FontWeight="Bold"
                                           FontSize="18"
                                           Foreground="#2C3E50"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,10"/>

                                <!-- Separator -->
                                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                        BorderBrush="#DADADA" 
                                        BorderThickness="0,1,0,0" 
                                        Margin="0,0,0,10"/>

                                <!-- Exchange Rate Option -->
                                <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                          Content="Use Exchange Rate (LBP)" 
                                          IsChecked="{Binding UseExchangeRate}"
                                          Foreground="#2C3E50"
                                          Margin="0,0,0,10"/>

                                <!-- Exchange Amount Display -->
                                <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                      Visibility="{Binding UseExchangeRate, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="AMOUNT IN LBP:" 
                                               FontWeight="Bold"
                                               Foreground="#2980B9"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding ExchangeAmount, StringFormat='LBP {0:N0}'}" 
                                               FontWeight="Bold"
                                               Foreground="#2980B9"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Payment Amount -->
                                <TextBlock Grid.Row="4" Grid.Column="0" 
                                           Text="PAYMENT AMOUNT:" 
                                           Foreground="#2C3E50"
                                           VerticalAlignment="Center"/>

                                <TextBox Grid.Row="4" Grid.Column="1" 
                                         Text="{Binding PaidAmount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="120"
                                         Height="32"
                                         Padding="5,0"
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Right"
                                         BorderBrush="#DADADA"/>

                                <!-- Debt Option -->
                                <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
                                          Content="Add remaining balance to customer debt" 
                                          IsChecked="{Binding AddToCustomerDebt}"
                                          Foreground="#2C3E50"
                                          Margin="0,10,0,0"/>

                                <!-- Debt Amount -->
                                <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" 
                                      Visibility="{Binding AddToCustomerDebt, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="AMOUNT TO ADD TO DEBT:" 
                                               FontWeight="Bold"
                                               Foreground="#E74C3C"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding AmountToDebt, StringFormat='${0:F2}'}" 
                                               FontWeight="Bold"
                                               Foreground="#E74C3C"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Checkout Button -->
                                <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                        Content="COMPLETE SALE" 
                                        Command="{Binding CheckoutCommand}"
                                        Height="44"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Background="#2ECC71" 
                                        Foreground="White"
                                        BorderThickness="0"
                                        Margin="0,15,0,0"
                                        Visibility="{Binding IsTransactionLoaded, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                                <!-- Print Button (when viewing transaction) -->
                                <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                        Content="PRINT RECEIPT" 
                                        Command="{Binding PrintReceiptCommand}"
                                        Height="44"
                                        FontSize="14"
                                        Background="#F39C12" 
                                        Foreground="White"
                                        BorderThickness="0"
                                        Margin="0,15,0,0"
                                        Visibility="{Binding IsTransactionLoaded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#ECF0F1" BorderBrush="#DADADA" BorderThickness="0,1,0,0" Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Status Message -->
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#2C3E50" VerticalAlignment="Center"/>

                    <!-- Transaction Info Banner -->
                    <Border Background="#D6EAF8" 
                            Visibility="{Binding IsTransactionLoaded, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="15,0,0,0" 
                            Padding="10,4" 
                            CornerRadius="3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Viewing Transaction #" Foreground="#2980B9" 
                                     Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            <TextBlock Text="EDITING Transaction #" Foreground="#E74C3C" FontWeight="Bold"
                                     Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding LoadedTransaction.TransactionId}" FontWeight="Bold" Foreground="#2980B9"/>
                            <TextBlock Text=" - " Foreground="#2980B9"/>
                            <TextBlock Text="{Binding LoadedTransaction.Status}" Foreground="#2980B9"/>
                            <TextBlock Text=" - " Foreground="#2980B9"/>
                            <TextBlock Text="{Binding LoadedTransaction.FormattedDate}" Foreground="#2980B9"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Progress Indicator -->
                <ProgressBar Grid.Column="1" 
                             IsIndeterminate="True" 
                             Width="120" 
                             Height="4"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>